{
  "name": "@vibeide/electron",
  "version": "1.0.0-7201",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node node_modules/concurrently/dist/bin/concurrently.js \"npm run dev:renderer\" \"npm run dev:electron\"",
    "desktop": "node node_modules/cross-env/src/bin/cross-env.js ELECTRON_DEV=1 node node_modules/concurrently/dist/bin/concurrently.js \"npm run dev:renderer -- --port 5173 --strictPort\" \"npm run dev:electron\"",
    "dev:renderer": "node node_modules/vite/bin/vite.js",
    "dev:electron": "node node_modules/typescript/lib/tsc.js && node node_modules/electron/cli.js .",
    "build:runtime": "npm --prefix ../runtime run build",
    "build:main": "node node_modules/typescript/lib/tsc.js",
    "build:renderer": "node node_modules/vite/bin/vite.js build",
    "build": "npm run build:runtime && npm run build:main && npm run build:renderer && node node_modules/electron-builder/cli.js",
    "pack:win": "npm run build:runtime && npm run build:main && npm run build:renderer && node scripts/pack_win_unpacked.cjs",
    "stamp:win": "node scripts/stamp_win_exe_version.cjs",
    "dist:win": "npm run build:runtime && npm run build:main && npm run build:renderer && node node_modules/electron-builder/cli.js --win --x64",
    "typecheck": "node node_modules/typescript/lib/tsc.js --noEmit",
    "verify:version": "node scripts/verify_version.cjs",
    "smoke:workbench": "node scripts/run_workbench_smoke.cjs",
    "smoke:chat-ui": "node scripts/verify_chat_ui.cjs",
    "verify:chat-presentation": "node scripts/verify_chat_presentation.cjs",
    "verify:session": "node node_modules/electron/cli.js scripts/verify_claude_session.cjs",
    "verify:hardboard": "node node_modules/electron/cli.js scripts/verify_hardboard_context_rules.cjs",
    "verify:skills": "node node_modules/electron/cli.js scripts/verify_skill_manager.cjs",
    "verify:release": "node scripts/verify_win_unpacked_release.cjs",
    "verify:first-run": "node scripts/verify_packaged_first_run.cjs",
    "verify:task-queue": "node node_modules/electron/cli.js scripts/verify_agent_task_queue.cjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "less": "^4.2.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
